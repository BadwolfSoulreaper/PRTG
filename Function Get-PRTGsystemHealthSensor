Function Get-PRTGsystemHealthSensor {
    param(
        [Parameter(Mandatory = $true)]
        $SensorID)
    $Sensor = get-sensor -Id $SensorID
    $ChartTitle = ("$($sensor.Probe) - $($sensor.Device) - $($sensor.Name)")
    $SensorHistory = get-sensor -Id $SensorID | Get-SensorHistory -EndDate ((get-date).AddDays(-30)) -Average 84700 | Select-Object @{N = 'Date'; E = { (Get-Date $_.Datetime -Format dd/MMM/yyyy) } }, Health, @{N = 'MemoryAvailable'; E = { $_.'AvailableMemory%' } }, @{N = 'RAMuseGB'; E = { $_.'MemoryUsage' } } | Sort-Object { [datetime]$_.Date }
    Return Get-LineGraph -ChartName $ChartTitle -XaxisLabels ($SensorHistory | Select-Object Date) -ValueType 'Percent' -Dataset1 ($SensorHistory | Select-Object 'Health') -Dataset2 ($SensorHistory | Select-Object 'MemoryAvailable')
}
