Function Get-PRTGprobeHealth {
    param(
        [Parameter(Mandatory = $true)]
        $SensorID)
    $Sensor = get-sensor -Id $SensorID
    $ChartTitle = ("$($sensor.Probe) - $($sensor.Device) - $($sensor.Name)")
    $SensorHistory = get-sensor -Id $SensorID | Get-SensorHistory -EndDate ((get-date).AddDays(-30)) -Average 84700 | Select-Object @{N = 'Date'; E = { (Get-Date $_.Datetime -Format dd/MMM/yyyy) } }, @{N = 'MsgQ'; E = { $_.'MessageQueue' } }, @{N = 'DelayWMI'; E = { $_.IntervalDelayWMI.Split(' ')[0] } }, @{N = 'RAMuseGB'; E = { $_.'MemoryUsage' } } | Sort-Object { [datetime]$_.Date }
    Return Get-LineGraph -ChartName $ChartTitle -XaxisLabels ($SensorHistory | Select-Object Date) -ValueType 'MsgQ Items, DelayWMI %, RAM Use (GB)' -Dataset1 ($SensorHistory | Select-Object 'MsgQ') -Dataset2 ($SensorHistory | Select-Object 'DelayWMI') -Dataset3  ($SensorHistory | Select-Object 'RAMuseGB')
}
