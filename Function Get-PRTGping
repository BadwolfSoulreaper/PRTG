Function Get-PRTGping
    {
        param(
        [Parameter(Mandatory=$true)]
        $SensorID)
        $Sensor = get-sensor -Id $SensorID
        $ChartTitle = ("$($sensor.Probe) - $($sensor.Device) - $($sensor.Name)")
        $SensorHistory = get-sensor -Id $SensorID | Get-SensorHistory -EndDate ((get-date).AddDays(-30)) -Average 84700 | Select-Object @{N='Date';E={(Get-Date $_.Datetime -Format dd/MMM/yyyy)}},@{N='PingTime(ms)';E={[int]$_.PingTime}},@{N='PacketLoss';E={[int]$_.PacketLoss}} | Sort-Object {[datetime]$_.Date}
        Return Get-LineGraph -ChartName $ChartTitle -XaxisLabels ($SensorHistory | Select-Object Date) -ValueType 'Time (ms), #Packets Dropped' -Dataset1 ($SensorHistory | Select-Object 'PingTime(ms)') -Dataset2 ($SensorHistory | Select-Object PacketLoss)
    }
