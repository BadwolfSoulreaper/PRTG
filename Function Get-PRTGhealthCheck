        Write-Output("╚════════════════════════════════════════════════════════════════════════════════════╝")
        (Get-Probe | Sort-Object Name).Name
        Write-Output("╔════════════════════════════════════════════════════════════════════════════════════╗")
        Write-Output("╚════════════════════════════════════════════════════════════════════════════════════╝")
    }
    else {
        Show-Kubus
        Write-Output("╔═════════════════════════════════════════════════════════════════════════════╗")
        Write-Output("║No customer found with the name $Customer.  Valid customer names listed below   ║")
        Write-Output("╚═════════════════════════════════════════════════════════════════════════════╝")
        (Get-Probe | Sort-Object Name).Name
        Write-Output("╔═════════════════════════════════════════════════════════════════════════════╗")
        Write-Output("╚═════════════════════════════════════════════════════════════════════════════╝")
    }
}
