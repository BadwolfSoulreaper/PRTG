            )
            $Sensor = Get-Sensor -Id $SensorID
            Return ([PSCustomObject]@{
                    Device = $Sensor.Device
                    Name   = $Sensor.Name
                    Status = $Sensor.DisplayLastValue
                })
        }
        
        Function Get-PRTGcoreHealthSensor {
            param(
                [parameter(Mandatory = $true)]
                $SensorID
            )
            $Sensor = Get-Sensor -Id $SensorID | Get-Channel | ConvertTo-ValueTable | Select Health, @{N = 'Queued Notifications'; E = { $_.'Notifications in Send Queue' } }, `
            @{N = 'Cfg Last Saved'; E = { $timespan = New-TimeSpan -Seconds ($_.'Configuration Last Saved'); "$($Timespan.Days)d $($Timespan.Hours)h $($Timespan.Minutes)m" } }, `
                'Raw Data Buffer', 'CPU Load', @{N = 'Free Phys Memory GB'; E = { [math]::round($_.'Free Physical Memory' / 1GB, 1) } }, @{N = 'Free Page Memory GB'; `
                    E                                                                                                                        = { [math]::round($_.'Free Page File Memory' / 1GB, 1) }
            }
            Return $Sensor
        }

        $Sensors = $Probe | Get-Sensor
