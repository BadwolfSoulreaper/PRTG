        Function Get-PRTGram {
            param(
                [Parameter(Mandatory = $true)]
                $SensorID,
                [int]$Dayrange = 30)
            $Sensor = get-sensor -Id $SensorID
            $SensorHistory = get-sensor -Id $SensorID | Get-SensorHistory -EndDate ((get-date).AddDays(-$Dayrange)) -Average 84700 | Select-Object @{N = 'Date'; E = { (Get-Date $_.Datetime -Format dd/MMM/yyyy) } }, @{N = 'Available'; E = { $_.'PercentAvailableMemory' } }, TotalMemory | Sort-Object { [datetime]$_.Date }
            $ChartTitle = ("$($sensor.Probe) - $($sensor.Device) - $($sensor.Name) - ($(($SensorHistory | Select-Object -First 1).TotalMemory)GB Total)")
            Return Get-LineGraph -ChartName $ChartTitle -XaxisLabels ($SensorHistory | Select-Object Date) -ValueType 'RAM (Percent)' -Dataset1 ($SensorHistory | Select-Object 'Available') 
        }
        Function Get-PRTGdiskFree {
            param(
                [Parameter(Mandatory = $true)]
                $SensorID,
                [int]$Dayrange = 30)
            $Sensor = get-sensor -Id $SensorID
            $SensorHistory = $Sensor | Get-SensorHistory -EndDate ((get-date).AddDays(-$Dayrange)) -Average 84700 | Select-Object @{N = 'Date'; E = { (Get-Date $_.Datetime -Format dd/MMM/yyyy) } }, @{N = 'PercentFree'; E = { $_.'FreeSpace' } }, Total | Sort-Object { [datetime]$_.Date }
            $ChartTitle = ("$($sensor.Probe) - $($sensor.Device) - $($sensor.Name) - ($(($SensorHistory | Select-Object -First 1).Total)GB Total)").Replace('\', '')
            Return Get-LineGraph -ChartName $ChartTitle -XaxisLabels ($SensorHistory | Select-Object Date) -ValueType "Percentage of free disk space" -Dataset1 ($SensorHistory | Select-Object 'PercentFree') 
        }

        Function Get-PRTGprobeHealth {
            param(
                [Parameter(Mandatory = $true)]
                $SensorID)
            $Sensor = get-sensor -Id $SensorID
            $Channel = $Sensor | Get-Channel
            Return ([PSCustomObject]@{
                    Device                        = $Sensor.Device
                    Health                        = (Get-LastValue -Table $Channel -Name 'Health')
                    'Open Requests (100)'         = (Get-LastValue -Table $Channel -Name 'Open Requests')
                    'Threads (1400)'              = (Get-LastValue -Table $Channel -Name 'Threads')
                    'Delay WMI (100)'             = (Get-LastValue -Table $Channel -Name 'Interval Delay WMI')
                    'Delay SNMP (100)'            = (Get-LastValue -Table $Channel -Name 'Interval Delay SNMP')
                    'Delay non-WMI or SNMP (100)' = (Get-LastValue -Table $Channel -Name 'Interval Delay non-WMI&SNMP')
                    'Memory Usage GB (3)'         = [math]::round((Get-LastValue -Table $Channel -Name 'Memory Usage') / 1gb, 2)
                    'Lost Packets (10)'           = (Get-LastValue -Table $Channel -Name 'Lost Flow Packets')
                    'Toplist Memory (2)'          = (Get-LastValue -Table $Channel -Name 'Toplist Memory')
                    'Storage Free GB'             = [math]::round((Get-LastValue -Table $Channel -Name 'Data Storage Free') / 1gb, 2)
                })
        }

        Function Get-PRTGsystemHealthSensor {
            param(
                [Parameter(Mandatory = $true)]
                $SensorID,
                [int]$Dayrange = 30)
            $Sensor = get-sensor -Id $SensorID
            $ChartTitle = ("$($sensor.Probe) - $($sensor.Device) - $($sensor.Name)")
            $SensorHistory = get-sensor -Id $SensorID | Get-SensorHistory -EndDate ((get-date).AddDays(-$Dayrange)) -Average 84700 | Select-Object @{N = 'Date'; E = { (Get-Date $_.Datetime -Format dd/MMM/yyyy) } }, Health, @{N = 'MemoryAvailable'; E = { $_.'AvailableMemory%' } }, @{N = 'RAMuseGB'; E = { $_.'MemoryUsage' } } , @{N = 'CPUload'; E = { $_.SystemCPULoad } } | Sort-Object { [datetime]$_.Date }
            if(($SensorHistory | Measure-Object Health -Sum).Sum) {
                Return Get-LineGraph -ChartName $ChartTitle -XaxisLabels ($SensorHistory | Select-Object Date) -ValueType 'Percent' -Dataset1 ($SensorHistory | Select-Object 'Health') -Dataset2 ($SensorHistory | Select-Object 'MemoryAvailable') -Dataset3 ($SensorHistory | Select-Object 'CPUload')
            }
        }

        Function Get-PRTGsystemUptime {
            param(
                [Parameter(Mandatory = $true)]
                $SensorID
            )
            Return (Get-Sensor -ID $SensorID | Select-Object Device, TotalUptime, TotalDowntime)
        }

        Function Get-PRTGwindowsUpdateStatus {
            param(
                [Parameter(Mandatory = $true)]
                $SensorID
            )
            $Sensor = Get-Sensor -Id $SensorID
            $Channel = $Sensor | Get-Channel
            $LastUpdated = New-TimeSpan -Seconds ($Channel | Where-Object { $_.Name -eq 'Time Since Last Update' }).LastValue
            Return ([PSCustomObject]@{
                    Device        = $Sensor.Device
                    'LastUpdated' = "$($LastUpdated.Days)d $($LastUpdated.Hours)h $($LastUpdated.Minutes)m"
                })
        }

        Function Get-PRTGwmiSecurityCentre {
            param(
