        Function Get-PrettyDate {
            param([datetime]$Date)
            if (!($Date)) {
                $Date = Get-Date
            }
            Switch ($Date.Day) {
                { $_ -in 1, 21, 31 } { $dateSuffix = 'st' }
                { $_ -in 2, 22 } { $dateSuffix = 'nd' }
                { $_ -in 3, 23 } { $dateSuffix = 'rd' }
                default { $dateSuffix = 'th' }
            }
            Write-Output("$($Date.Day)$dateSuffix of $(Get-date -Date $Date -Format 'MMMM yyyy - HH:mm')")
        }
        function ConvertTo-ValueTable {
            [CmdletBinding()]
            param (
                [Parameter(
                    Mandatory,
                    ValueFromPipeline
                )]
                [object[]]$InputObject
            )

            begin {
                $Properties = [ordered]@{}
            }

            process {
                foreach ($Row in $InputObject) {
                    if ($null -ne $Row.Name) {
                        $Properties[$Row.Name.ToString().Trim()] = $Row.LastValue
                    }
                }
            }

            end {
                [PSCustomObject]$Properties
            }
        }
        Function Get-LastValue {
            Param($Table, $Name)
            Return ($Table | Where-Object { $_.Name -eq $Name }).LastValue
        }

        Function Get-PRTGping {
            param(
                [Parameter(Mandatory = $true)]
                $SensorID,
                [int]$Dayrange = 30)
            $Sensor = get-sensor -Id $SensorID
            $ChartTitle = ("$($sensor.Probe) - $($sensor.Device) - $($sensor.Group)")
            $SensorHistory = get-sensor -Id $SensorID | Get-SensorHistory -EndDate ((get-date).AddDays(-$Dayrange)) -Average 84700 | Select-Object @{N = 'Date'; E = { (Get-Date $_.Datetime -Format dd/MMM/yyyy) } }, @{N = 'PingTime(ms)'; E = { [int]$_.PingTime } }, @{N = 'PacketLoss'; E = { [int]$_.PacketLoss } } | Sort-Object { [datetime]$_.Date }
            Return Get-LineGraph -ChartName $ChartTitle -XaxisLabels ($SensorHistory | Select-Object Date) -ValueType 'Time (ms), #Packets Dropped' -Dataset1 ($SensorHistory | Select-Object 'PingTime(ms)') -Dataset2 ($SensorHistory | Select-Object PacketLoss)
        }

        Function Get-PRTGnetworkTraffic {
            param(
                [Parameter(Mandatory = $true)]
                $SensorID,
                [int]$Dayrange = 30)
            $Sensor = get-sensor -Id $SensorID
            $ChartTitle = ("$($sensor.Probe) - $($sensor.Device) - $($sensor.Name)")
            $SensorHistory = get-sensor -Id $SensorID | Get-SensorHistory -EndDate ((get-date).AddDays(-$Dayrange)) -Average 84700 | Select-Object @{N = 'Date'; E = { (Get-Date $_.Datetime -Format dd/MMM/yyyy) } }, @{N = 'Total'; E = { $_.'TrafficTotal(Volume)' } }, @{N = 'In'; E = { $_.'TrafficIn(Volume)' } }, @{N = 'Out'; E = { $_.'TrafficOut(Volume)' } } | Sort-Object { [datetime]$_.Date }
            if (!($SensorHistory | Select-Object -First 1).Total) {
                $SensorHistory = get-sensor -Id $SensorID | Get-SensorHistory -EndDate ((get-date).AddDays(-$Dayrange)) -Average 84700 | Select-Object @{N = 'Date'; E = { (Get-Date $_.Datetime -Format dd/MMM/yyyy) } }, @{N = 'Total'; E = { $_.'Total(Volume)' } }, @{N = 'In'; E = { $_.'TrafficIn(Volume)' } }, @{N = 'Out'; E = { $_.'TrafficOut(Volume)' } } | Sort-Object { [datetime]$_.Date }    
            }
            if (($SensorHistory | Measure-Object Total -Sum).Sum) {
                Return Get-LineGraph -ChartName $ChartTitle -XaxisLabels ($SensorHistory | Select-Object Date) -ValueType 'Network Traffic (MB)' -Dataset1 ($SensorHistory | Select-Object 'Total') -Dataset2 ($SensorHistory | Select-Object 'In') -Dataset3  ($SensorHistory | Select-Object 'Out')
            }
            else {
                Return $null
            }
        }

